# =========================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =========================================================
# Si usas Docker Compose, POSTGRES_SERVER debe ser el nombre del servicio: 'db'
# Si ejecutas localmente (sin Docker), usa: 'localhost'
POSTGRES_SERVER=db
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret_password
POSTGRES_DB=talento_up_db
POSTGRES_PORT=5432

# =========================================================
# SEGURIDAD
# =========================================================
# IMPORTANTE: Cambiar esto en producción.
# Puedes generar una clave segura ejecutando: openssl rand -hex 32
SECRET_KEY=cambiar_esto_por_una_cadena_larga_y_aleatoria_insegura_para_dev
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# =========================================================
# CONFIGURACIÓN DE CORREO (SMTP)
# =========================================================
# Si SMTP_ENABLED es False, los correos solo se imprimen en la consola (Logs).
# Si es True, intenta conectar al servidor SMTP.
SMTP_ENABLED=False

# Configuración para Gmail (requiere Contraseña de Aplicación) o Outlook
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_contraseña_de_aplicacion
SMTP_TLS=True

# Remitente por defecto
EMAILS_FROM_EMAIL=talento@up.edu.pe
EMAILS_FROM_NAME="Talento Humano UP"

# =========================================================
# EXTRAS
# =========================================================
# Opcional: API Key para funcionalidades de IA (Google Gemini)
GEMINI_API_KEY=